# 앱 클라이언트에 노출됨 (EXPO_PUBLIC_ 접두어만 허용)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# 선택값. 비어 있으면 쿠팡 검색 웹 URL로 폴백합니다.
# 발급받은 쿠팡 파트너스 채널 태그(LPtag)를 넣으면 수수료 추적 링크로 래핑됩니다.
EXPO_PUBLIC_COUPANG_PARTNER_TAG=

# Phase 4에서 사용 — Supabase Edge Function secret 전용.
# 앱 번들에 절대 포함 금지. 배포는 `supabase secrets set GEMINI_API_KEY=...`로.
GEMINI_API_KEY=
